# Copy to .env on the host before `docker compose up`.
# Secrets are not baked into the image — pass them at runtime.

# Persistent SQLite directory inside the container (mount a volume here in compose)
DATA_DIR=/app/data
# Optional: full path to the DB file instead of DATA_DIR/scanner.db
# DATABASE_PATH=/app/data/scanner.db

# Public URL for push notifications and absolute links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron endpoint auth (required in production)
CRON_SECRET=

# Firebase (server)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_CREDENTIALS=/run/secrets/firebase-credentials.json

# Firebase (client — defaults exist in code; override if needed)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# AI briefs (optional)
# PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar
# GEMINI_API_KEY=
# GEMINI_MODEL=

# Reddit trending (optional)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=stonks-scanner/1.0

# Registry tag when building/pushing (used by docker compose)
# DOCKER_IMAGE=ghcr.io/pratishbodhale/stonks-os-app:latest
